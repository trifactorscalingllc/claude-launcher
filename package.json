{
  "name": "claude-launcher",
  "version": "1.4.4",
  "description": "Claude Helm — monitor and open all your Claude Code projects",
  "main": "main.js",
  "author": "biery",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.biery.claudelauncher",
    "productName": "Claude Helm",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "trifactorscalingllc",
        "repo": "claude-helm",
        "releaseType": "release"
      }
    ],
    "files": [
      "main.js",
      "indexer.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "icon.ico",
      "icon.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "Claude-Helm-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "artifactName": "Claude-Helm-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Development",
      "artifactName": "Claude-Helm-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Claude Helm"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "electron-updater": "^6.8.9"
  }
}
